<?xml version="1.0" ?>
<robot name="turtlebot3_burger" xmlns:xacro="http://ros.org/wiki/xacro">
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed"><parent link="base_footprint"/><child link="base_link"/><origin xyz="0 0 0.01" rpy="0 0 0"/></joint>
  <link name="base_link">
    <visual><origin xyz="0 0 0.07" rpy="0 0 0"/><geometry><cylinder length="0.14" radius="0.04"/></geometry></visual>
    <collision><origin xyz="0 0 0.07" rpy="0 0 0"/><geometry><cylinder length="0.14" radius="0.04"/></geometry></collision>
    <inertial><origin xyz="0 0 0.01" rpy="0 0 0"/><mass value="2.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial>
  </link>
  <joint name="l_wheel_joint" type="continuous"><parent link="base_link"/><child link="l_link"/><origin xyz="0 0.06 0.023" rpy="-1.57 0 0"/><axis xyz="0 0 1"/></joint>
  <link name="l_link"><visual><geometry><cylinder length="0.01" radius="0.03"/></geometry></visual><collision><geometry><cylinder length="0.01" radius="0.03"/></geometry></collision><inertial><mass value="0.1"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial></link>
  <joint name="r_wheel_joint" type="continuous"><parent link="base_link"/><child link="r_link"/><origin xyz="0 -0.06 0.023" rpy="-1.57 0 0"/><axis xyz="0 0 1"/></joint>
  <link name="r_link"><visual><geometry><cylinder length="0.01" radius="0.03"/></geometry></visual><collision><geometry><cylinder length="0.01" radius="0.03"/></geometry></collision><inertial><mass value="0.1"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial></link>
  <gazebo><plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so"><commandTopic>cmd_vel</commandTopic><odometryTopic>odom</odometryTopic><odometryFrame>odom</odometryFrame><robotBaseFrame>base_footprint</robotBaseFrame><publishWheelTF>false</publishWheelTF><publishTf>true</publishTf><updateRate>30</updateRate><leftJoint>l_wheel_joint</leftJoint><rightJoint>r_wheel_joint</rightJoint><wheelSeparation>0.12</wheelSeparation><wheelDiameter>0.066</wheelDiameter><wheelAcceleration>1</wheelAcceleration><wheelTorque>20</wheelTorque></plugin></gazebo>
</robot>
